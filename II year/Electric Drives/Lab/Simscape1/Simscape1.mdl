              <Prompt>Fundamental sample time (s)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Tsc">
              <Prompt>Control sample time (s)</Prompt>
            </DialogControl>
          </DialogControl>
          <DialogControl Type="Tab" Name="Container7">
