            <DialogControl Type="Popup" Name="CtrlType">
              <Prompt>Control type</Prompt>
              <ControlOptions PromptLocation="left"/>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kp_w">
              <Prompt>Controller proportional gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Ki_w">
              <Prompt>Controller integral gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kv_w">
              <Prompt>P controller proportional gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kaw_w">
              <Prompt>Integral anti-windup gain</Prompt>
            </DialogControl>
