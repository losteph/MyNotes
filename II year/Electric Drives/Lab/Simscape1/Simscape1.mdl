            <DialogControl Type="Edit" Name="ModFactor">
              <Prompt>Modulation factor</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="idMatrix">
              <Prompt>D-axis current reference matrix, id(wMechanical,TqRef,Vdc), (A)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="iqMatrix">
              <Prompt>Q-axis current reference matrix, iq(wMechanical,TqRef,Vdc), (A)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="psim">
              <Prompt>Permanent magnet flux linkage (Wb)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Ld">
              <Prompt>D-axis inductance (H)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Lq">
              <Prompt>Q-axis inductance (H)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Rs">
              <Prompt>Stator resistance (Ohm)</Prompt>
            </DialogControl>
          </DialogControl>
          <DialogControl Type="Tab" Name="Container8">
            <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:tab_InnerLoop</Prompt>
            <DialogControl Type="Popup" Name="AxisAlignment">
