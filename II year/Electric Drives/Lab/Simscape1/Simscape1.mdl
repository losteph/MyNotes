              <Prompt>Phase-a axis alignment</Prompt>
              <ControlOptions PromptLocation="left"/>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kp_id">
              <Prompt>D-axis current proportional gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Ki_id">
              <Prompt>D-axis current integral gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kaw_id">
