      <P Name="ComponentPath">foundation.mechanical.rotational.reference</P>
      <P Name="ComponentVariants">foundation.mechanical.rotational.reference</P>
      <P Name="ComponentVariantNames">reference</P>
      <P Name="ClassName">reference</P>
      <P Name="SchemaVersion">1</P>
    </InstanceData>
  </Block>
  <Block BlockType="SubSystem" Name="PMSM Field-Oriented&#xA;Control" SID="954">
    <PortCounts in="5" out="2"/>
    <P Name="Position">[615, 526, 750, 864]</P>
    <P Name="ZOrder">5878</P>
    <P Name="ForegroundColor">yellow</P>
    <P Name="HideAutomaticName">off</P>
    <P Name="AncestorBlock">eePmsmFieldOrientedControl/PMSM Field-Oriented
Control</P>
    <P Name="LibraryVersion">*1.103</P>
    <P Name="CopyFcn">ee_sli_rtmsupport( &apos;copyfcn&apos;, gcbh );</P>
    <P Name="DeleteFcn">ee_sli_rtmsupport( &apos;deletefcn&apos;, gcbh );</P>
    <P Name="LoadFcn">ee_sli_rtmsupport( &apos;loadfcn&apos;, gcbh );</P>
    <P Name="ModelCloseFcn">ee_sli_rtmsupport( &apos;modelclosefcn&apos;, gcbh );</P>
    <P Name="PostSaveFcn">ee_sli_rtmsupport( &apos;postsavefcn&apos;, gcbh );</P>
    <P Name="PreCopyFcn">ee_sli_rtmsupport( &apos;precopyfcn&apos;, gcbh );</P>
    <P Name="OpenFcn">ee_sli_rtmsupport( &apos;openfcn&apos;, gcbh );</P>
    <P Name="CloseFcn">ee_sli_rtmsupport( &apos;closefcn&apos;, gcbh );</P>
    <P Name="PreDeleteFcn">ee_sli_rtmsupport( &apos;predeletefcn&apos;, gcbh );</P>
    <P Name="ContentPreviewEnabled">on</P>
    <Mask>
      <Type>PMSM Field-Oriented Control</Type>
      <Display RunInitForIconRedraw="off"/>
      <Description>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PMSMFieldOrientedControl_MD</Description>
      <Initialization>
if ParamTypeFF == 1
    idVect = [-200, 200];
    iqVect = [-200, 200];
    LdMatrix = LdFF*ones(2, 2);
    LqMatrix = LqFF*ones(2, 2);
    psimMatrix = psimFF*ones(2, 2);
end

switch CPWMMode
    case &apos;SPWM: sinusoidal PWM&apos;
        set_param(gcb,&apos;PWMMode&apos;,&apos;SPWM: sinusoidal PWM&apos;);
    case &apos;SVM: space vector modulation&apos;
        set_param(gcb,&apos;PWMMode&apos;,&apos;SVM: space vector modulation&apos;)
end</Initialization>
      <Help>web(nesl_help(gcbh))</Help>
      <MaskParameter Name="CtrlMode" Type="popup">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:ControlMode_MP</Prompt>
        <Value>Velocity control</Value>
        <Callback>ee.mask.callbackPopupPmsmFoc(gcb);</Callback>
        <TypeOptions>
          <Option>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:VelocityControl_PV</Option>
          <Option>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:TorqueControl_PV</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Vnom" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:NominalDclinkVoltageV_MP</Prompt>
        <Value>Vdc</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/Vnom</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Pmax" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:MaximumPowerW_MP</Prompt>
        <Value>Pmax</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/Pmax</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Tmax" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:MaximumTorqueNm_MP</Prompt>
        <Value>Tmax</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/Tmax</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="p" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:NumberOfRotorPolePairs_MP</Prompt>
        <Value>np</Value>
      </MaskParameter>
      <MaskParameter Name="Vdc_on" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:InverterDclinkVoltageThresholdV_MP</Prompt>
        <Value>10</Value>
      </MaskParameter>
      <MaskParameter Name="Ts" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:FundamentalSampleTimes_MP</Prompt>
        <Value>TT_c</Value>
      </MaskParameter>
      <MaskParameter Name="Tsc" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:ControlSampleTimes_MP</Prompt>
        <Value>TT_sc</Value>
      </MaskParameter>
      <MaskParameter Name="CtrlType" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:ControlType_MP</Prompt>
        <Value>PI control</Value>
        <Callback>ee.mask.callbackPopupPmsmFoc(gcb);</Callback>
        <TypeOptions>
          <Option>Outer loop control/Velocity Controller/CtrlType</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kp_w" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:ControllerProportionalGain_MP</Prompt>
        <Value>kpwr*np*3*np*Psim/2</Value>
        <TypeOptions>
          <Option>Outer loop control/Velocity Controller/Kp_w</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Ki_w" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:ControllerIntegralGain_MP</Prompt>
        <Value>kiwr*np*3*np*Psim/2</Value>
        <TypeOptions>
          <Option>Outer loop control/Velocity Controller/Ki_w</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kv_w" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PControllerProportionalGain_MP</Prompt>
        <Value>1</Value>
        <TypeOptions>
          <Option>Outer loop control/Velocity Controller/Kv_w</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kaw_w" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:IntegralAntiwindupGain_MP</Prompt>
        <Value>kawr</Value>
        <TypeOptions>
          <Option>Outer loop control/Velocity Controller/Kaw_w</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="RefType" Type="promote" Evaluate="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:CurrentReferences_MP</Prompt>
        <Value>Zero d-axis control</Value>
        <Callback>ee.mask.callbackPopupPmsmFoc(gcb);</Callback>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/RefType</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="rpmVec" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:MechanicalSpeedVectorWMechanicalrpm_MP</Prompt>
        <Value>[0, 3000]</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/rpmVec</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="TqVec" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:TorqueReferenceVectorTqRefNm_MP</Prompt>
        <Value>[-100, 0, 100]</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/TqVec</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="VdcVec" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DClinkVoltageVectorVdcV_MP</Prompt>
        <Value>[300, 350]</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/VdcVec</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="PWMMode" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmCurrentReferenceGen:PWMMethod_MP</Prompt>
        <Value>SPWM: sinusoidal PWM</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/PWMMode</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="ModFactor" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmCurrentReferenceGen:ModulationFactor_MP</Prompt>
        <Value>1</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/ModFactor</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="idMatrix" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisCurrentReferenceMatrixIdwMechanicalTqRefVdcA_MP</Prompt>
        <Value>zeros(2,3,2)</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/idMatrix</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="iqMatrix" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisCurrentReferenceMatrixIqwMechanicalTqRefVdcA_MP</Prompt>
        <Value>zeros(2,3,2)</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/iqMatrix</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="psim" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PermanentMagnetFluxLinkageWb_MP</Prompt>
        <Value>Psim</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/psim</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Ld" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisInductanceH_MP</Prompt>
        <Value>0.00024</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/Ld</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Lq" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisInductanceH_MP</Prompt>
        <Value>0.00029</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/Lq</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Rs" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:StatorResistanceOhm_MP</Prompt>
        <Value>0.01</Value>
        <TypeOptions>
          <Option>Outer loop control/PMSM Current Reference
Generator/Rs</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="AxisAlignment" Type="promote" Evaluate="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PhaseaAxisAlignment_MP</Prompt>
        <Value>D-axis</Value>
        <TypeOptions>
          <Option>Inner loop control/Park Transform/AxisAlignment</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kp_id" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisCurrentProportionalGain_MP</Prompt>
        <Value>kpisd</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/Kp_id</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Ki_id" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisCurrentIntegralGain_MP</Prompt>
        <Value>kiisd</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/Ki_id</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kaw_id" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisCurrentAntiwindupGain_MP</Prompt>
        <Value>kaisd</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/Kaw_id</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kp_iq" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisCurrentProportionalGain_MP</Prompt>
        <Value>kpisq</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/Kp_iq</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Ki_iq" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisCurrentIntegralGain_MP</Prompt>
        <Value>kiisq</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/Ki_iq</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="Kaw_iq" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisCurrentAntiwindupGain_MP</Prompt>
        <Value>kaisq</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/Kaw_iq</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="AxisPrio" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:AxisPrioritization_MP</Prompt>
        <Value>D-Q equivalence</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/AxisPrio</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="ActZC" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:EnableZeroCancellation_MP</Prompt>
        <Value>off</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/ActZC</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="ActFF" Type="promote">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:EnablePrecontrolVoltage_MP</Prompt>
        <Value>on</Value>
        <Callback>ee.mask.callbackPopupPmsmFoc(gcb);</Callback>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/ActFF</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="ParamTypeFF" Type="popup">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:MachineParameters_MP</Prompt>
        <Value>Constant parameters</Value>
        <Callback>ee.mask.callbackPopupPmsmFoc(gcb);</Callback>
        <TypeOptions>
          <Option>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:ConstantParameters_PV</Option>
          <Option>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:LookupTableBasedParameters_PV</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="LdFF" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisInductanceForFeedforwardPrecontrolH_MP</Prompt>
        <Value>Lsd</Value>
      </MaskParameter>
      <MaskParameter Name="LqFF" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisInductanceForFeedforwardPrecontrolH_MP</Prompt>
        <Value>Lsq</Value>
      </MaskParameter>
      <MaskParameter Name="psimFF" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PermanentMagnetFluxLinkageForFeedforwardPrecontrolWb_MP</Prompt>
        <Value>Psim</Value>
      </MaskParameter>
      <MaskParameter Name="idVect" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:DaxisCurrentVectorIdA_MP</Prompt>
        <Value>[-200, 0, 200]</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/idVect</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="iqVect" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:QaxisCurrentVectorIqA_MP</Prompt>
        <Value>[-200, 0, 200]</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/iqVect</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="LdMatrix" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:LdMatrixLdidiqH_MP</Prompt>
        <Value>0.0002 * ones(3, 3)</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/LdMatrix</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="LqMatrix" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:LqMatrixLqidiqH_MP</Prompt>
        <Value>0.0002 * ones(3, 3)</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/LqMatrix</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="psimMatrix" Type="promote" Visible="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PermanentMagnetFluxLinkageMatrixPMidiqWb_MP</Prompt>
        <Value>0.04 * ones(3, 3)</Value>
        <TypeOptions>
          <Option>Inner loop control/PMSM Current Controller
with Pre-Control/psimMatrix</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="CPWMMode" Type="promote" Evaluate="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:PWMMethod_MP</Prompt>
        <Value>SPWM: sinusoidal PWM</Value>
        <TypeOptions>
          <Option>PWM/PWM Generator
(Three-phase, Two-level)/CPWMMode</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="SamplingMode" Type="promote" Evaluate="off" Tunable="off">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:SamplingMode_MP</Prompt>
        <Value>Symmetric</Value>
        <TypeOptions>
          <Option>PWM/PWM Generator
(Three-phase, Two-level)/SamplingMode</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="fsw" Type="edit">
        <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:SwitchingFrequencyHz_MP</Prompt>
        <Value>1/TT_swt</Value>
      </MaskParameter>
      <DialogControl Type="Group" Name="DescGroupVar">
        <Prompt>%&lt;MaskType&gt;</Prompt>
        <DialogControl Type="Text" Name="DescTextVar">
          <Prompt>%&lt;MaskDescription&gt;</Prompt>
        </DialogControl>
      </DialogControl>
      <DialogControl Type="Group" Name="ParameterGroupVar">
        <Prompt>Simulink:studio:ToolBarParametersMenu</Prompt>
        <DialogControl Type="TabContainer" Name="Container3">
          <DialogControl Type="Tab" Name="Container4">
            <Prompt>physmod:ee:library:comments:control:eePmsmFieldOrientedControl:tab_General</Prompt>
