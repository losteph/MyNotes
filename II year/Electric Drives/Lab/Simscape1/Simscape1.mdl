              <ControlOptions PromptLocation="left"/>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kp_id">
              <Prompt>D-axis current proportional gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Ki_id">
              <Prompt>D-axis current integral gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kaw_id">
              <Prompt>D-axis current anti-windup gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kp_iq">
              <Prompt>Q-axis current proportional gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Ki_iq">
              <Prompt>Q-axis current integral gain</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="Kaw_iq">
              <Prompt>Q-axis current anti-windup gain</Prompt>
            </DialogControl>
            <DialogControl Type="Popup" Name="AxisPrio">
              <Prompt>Axis prioritization</Prompt>
              <ControlOptions PromptLocation="left"/>
            </DialogControl>
            <DialogControl Type="CheckBox" Name="ActZC">
              <Prompt>Enable zero cancellation</Prompt>
              <ControlOptions PromptLocation="&lt;unknown&gt;"/>
            </DialogControl>
            <DialogControl Type="CheckBox" Name="ActFF">
              <Prompt>Enable pre-control voltage</Prompt>
              <ControlOptions Row="current" PromptLocation="&lt;unknown&gt;"/>
            </DialogControl>
            <DialogControl Type="Popup" Name="ParamTypeFF">
              <Prompt>Machine parameters</Prompt>
              <ControlOptions PromptLocation="left"/>
            </DialogControl>
            <DialogControl Type="Edit" Name="LdFF">
              <Prompt>D-axis inductance for feed-forward pre-control (H)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="LqFF">
              <Prompt>Q-axis inductance for feed-forward pre-control (H)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="psimFF">
              <Prompt>Permanent magnet flux linkage for feed-forward pre-control (Wb)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="idVect">
              <Prompt>D-axis current vector, id (A)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="iqVect">
              <Prompt>Q-axis current vector, iq (A)</Prompt>
            </DialogControl>
            <DialogControl Type="Edit" Name="LdMatrix">
