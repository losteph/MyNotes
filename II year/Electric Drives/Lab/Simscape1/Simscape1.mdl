__MWOPC_PART_BEGIN__ /simulink/bddefaults.xml
<?xml version="1.0" encoding="utf-8"?>
<BlockDiagramDefaults>
  <AnnotationDefaults>
    <P Name="HorizontalAlignment">center</P>
    <P Name="VerticalAlignment">middle</P>
  </AnnotationDefaults>
  <MaskDefaults SelfModifiable="off">
    <Display IconFrame="on" IconOpaque="opaque" RunInitForIconRedraw="analyze" IconRotate="none" PortRotate="default" IconUnits="autoscale"/>
    <MaskParameter Evaluate="on" Tunable="on" NeverSave="off" Internal="off" ReadOnly="off" Enabled="on" Visible="on" ToolTip="on"/>
    <DialogControl>
      <ControlOptions Visible="on" Enabled="on" Row="new" HorizontalStretch="on" PromptLocation="top" Orientation="horizontal" Scale="linear" TextType="Plain Text" Expand="off" ShowFilter="on" ShowParameterName="on" WordWrap="on" AlignPrompts="off"/>
    </DialogControl>
  </MaskDefaults>
  <BlockParameterDefaults>
    <Block BlockType="BusCreator">
      <P Name="DisplayOption">none</P>
      <P Name="OutDataTypeStr">Inherit: auto</P>
      <P Name="NonVirtualBus">off</P>
    </Block>
    <Block BlockType="BusSelector">
      <P Name="OutputAsBus">off</P>
    </Block>
    <Block BlockType="Clock">
      <P Name="DisplayTime">off</P>
      <P Name="Decimation">10</P>
    </Block>
    <Block BlockType="Constant">
      <P Name="Value">1</P>
      <P Name="VectorParams1D">on</P>
      <P Name="SamplingMode">Sample based</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Inherit from &apos;Constant value&apos;</P>
      <P Name="LockScale">off</P>
      <P Name="SampleTime">inf</P>
      <P Name="FramePeriod">inf</P>
      <P Name="PreserveConstantTs">off</P>
    </Block>
    <Block BlockType="Demux">
      <P Name="Outputs">4</P>
      <P Name="DisplayOption">bar</P>
      <P Name="BusSelectionMode">off</P>
    </Block>
    <Block BlockType="DiscreteTransferFcn">
      <P Name="NumeratorSource">Dialog</P>
      <P Name="Numerator">[1]</P>
      <P Name="DenominatorSource">Dialog</P>
      <P Name="Denominator">[1 0.5]</P>
      <P Name="InitialStatesSource">Dialog</P>
      <P Name="InitialStates">0</P>
      <P Name="InputProcessing">Elements as channels (sample based)</P>
      <P Name="ExternalReset">None</P>
      <P Name="InitialDenominatorStates">0</P>
      <P Name="FilterStructure">Direct form II</P>
      <P Name="SampleTime">-1</P>
      <P Name="a0EqualsOne">off</P>
      <P Name="NumCoefMin">[]</P>
      <P Name="NumCoefMax">[]</P>
      <P Name="DenCoefMin">[]</P>
      <P Name="DenCoefMax">[]</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="StateDataTypeStr">Inherit: Same as input</P>
      <P Name="MultiplicandDataTypeStr">Inherit: Same as input</P>
      <P Name="NumCoefDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="DenCoefDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="NumProductDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="DenProductDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="NumAccumDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="DenAccumDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="OutDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">off</P>
      <P Name="StateMustResolveToSignalObject">off</P>
    </Block>
    <Block BlockType="DownSample">
      <P Name="N">2</P>
      <P Name="phase">0</P>
      <P Name="InputProcessing">Columns as channels (frame based)</P>
      <P Name="RateOptions">Enforce single-rate processing</P>
      <P Name="ic">0</P>
    </Block>
    <Block BlockType="From">
      <P Name="GotoTag">A</P>
      <P Name="IconDisplay">Tag</P>
      <P Name="TagVisibility">local</P>
    </Block>
    <Block BlockType="Gain">
      <P Name="Gain">1</P>
      <P Name="Multiplication">Element-wise(K.*u)</P>
      <P Name="ParamMin">[]</P>
      <P Name="ParamMax">[]</P>
      <P Name="ParamDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="Goto">
      <P Name="GotoTag">A</P>
      <P Name="IconDisplay">Tag</P>
      <P Name="TagVisibility">local</P>
    </Block>
    <Block BlockType="Inport">
      <P Name="Port">1</P>
      <P Name="AllowServiceAccess">off</P>
      <P Name="IconDisplay">Port number</P>
      <P Name="OutputFunctionCall">off</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: auto</P>
      <P Name="LockScale">off</P>
      <P Name="BusOutputAsStruct">off</P>
      <P Name="Unit">inherit</P>
      <P Name="PortDimensions">-1</P>
      <P Name="VarSizeSig">Inherit</P>
      <P Name="SampleTime">-1</P>
      <P Name="SignalType">auto</P>
      <P Name="SamplingMode">auto</P>
      <P Name="LatchByDelayingOutsideSignal">off</P>
      <P Name="LatchInputForFeedbackSignals">off</P>
      <P Name="Interpolate">on</P>
    </Block>
    <Block BlockType="Lookup_n-D">
      <P Name="NumberOfTableDimensions">2</P>
      <P Name="DataSpecification">Table and breakpoints</P>
      <P Name="BreakpointsSpecification">Explicit values</P>
      <P Name="BreakpointsForDimension1Source">Dialog</P>
      <P Name="BreakpointsForDimension1">[10,22,31]</P>
      <P Name="BreakpointsForDimension2Source">Dialog</P>
      <P Name="BreakpointsForDimension2">[10,22,31]</P>
